# Copy this file to `.env` and fill in your Supabase project values.
# Supabase Dashboard ▸ Project Settings ▸ API
#
# Both must start with EXPO_PUBLIC_ so Expo exposes them to the app.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Web landing page: direct-download link for the Android APK
# (e.g. a GitHub Releases asset or Supabase Storage public URL).
# Leave empty to show a "coming soon" message.
EXPO_PUBLIC_APK_URL=